{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting": "Information"
      }
    }
  },
  "GameServer": {
    "AllowDynamicPort": true
  },
  "Telemetry": {
    "TraceSamplingRatio": 0.01
  },
  "Node": {
    "MaxHandShakeRetries": 1
  }
}
