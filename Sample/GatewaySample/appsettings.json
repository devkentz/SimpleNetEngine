{
  "Gateway": {
    "ClientHost": "0.0.0.0",
    "AllowDynamicPort": true,
    "SigningKeyPath": "../certs/server_signing_key.pem"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting": "Information"
      }
    }
  },
  "Telemetry": {
    "TraceSamplingRatio": 0.01
  },
  "Node": {
    "MaxHandShakeRetries": 1
  },
  "AllowedHosts": "*"
}
